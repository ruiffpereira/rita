---
import Layout from '../layouts/Layout.astro';
import ArtistCard from '../components/ArtistCard.astro';
import BodyPartCard from '../components/BodyPartCard.astro';
import { artists } from '../data/artists';
import { bodyParts } from '../data/bodyParts';
---

<Layout title="Home" description="NØVA Piercing Boutique — Arte profissional de piercing no Porto">

  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-(--color-dark-900)">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full blur-[140px]" style="background: color-mix(in srgb, var(--color-gold-500) 8%, transparent);"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full blur-[120px]" style="background: color-mix(in srgb, var(--color-gold-400) 6%, transparent);"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(0,0,0,.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,.2) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20 text-center">
      <div class="animate-fade-up delay-100 inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-(--color-gold-500)/30 mb-8" style="background: color-mix(in srgb, var(--color-gold-500) 10%, transparent);">
        <span class="w-1.5 h-1.5 rounded-full bg-(--color-gold-500) animate-pulse"></span>
        <span class="text-(--color-gold-500) text-xs font-medium uppercase tracking-widest">Studio Profissional · Porto</span>
      </div>
      <h1 class="animate-fade-up delay-200 font-(--font-display) text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-gray-900 leading-[1.05] mb-6">
        Arte que<br />
        <span style="background: linear-gradient(135deg, var(--color-gold-400), var(--color-gold-600)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">vives na pele</span>
      </h1>
      <p class="animate-fade-up delay-300 max-w-2xl mx-auto text-gray-500 text-lg sm:text-xl leading-relaxed mb-10">Somos uma piercing boutique no Porto dedicada à perfeição. Cada trabalho é único, feito com arte, precisão e os mais altos padrões de higiene.</p>
      <div class="animate-fade-up delay-400 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/#artistas" class="w-full sm:w-auto px-8 py-4 bg-(--color-gold-500) hover:bg-(--color-gold-400) text-white font-semibold rounded-full transition-all duration-300 hover:scale-105 uppercase tracking-wider text-sm" style="box-shadow: 0 4px 30px color-mix(in srgb, var(--color-gold-500) 30%, transparent);">Conhecer os Artistas</a>
        <a href="/#categorias" class="w-full sm:w-auto px-8 py-4 border border-(--color-gold-500)/40 hover:border-(--color-gold-500) text-gray-700 hover:text-(--color-gold-500) font-medium rounded-full transition-all duration-300 uppercase tracking-wider text-sm">Explorar Galeria</a>
      </div>
      <div class="animate-fade-up delay-500 grid grid-cols-3 gap-6 max-w-sm mx-auto mt-20 pt-10 border-t border-black/10">
        <div><p class="font-(--font-display) text-3xl font-bold text-gray-900">4</p><p class="text-gray-400 text-xs mt-1 uppercase tracking-widest">Artistas</p></div>
        <div><p class="font-(--font-display) text-3xl font-bold text-(--color-gold-500)">738+</p><p class="text-gray-400 text-xs mt-1 uppercase tracking-widest">Trabalhos</p></div>
        <div><p class="font-(--font-display) text-3xl font-bold text-gray-900">8+</p><p class="text-gray-400 text-xs mt-1 uppercase tracking-widest">Anos</p></div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-400">
      <span class="text-xs uppercase tracking-widest">Explorar</span>
      <div class="w-px h-8 bg-gradient-to-b from-gray-400 to-transparent"></div>
    </div>
  </section>

  <section id="artistas" class="py-24 lg:py-32 bg-(--color-dark-800)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal text-center mb-16">
        <p class="text-(--color-gold-500) text-xs font-medium uppercase tracking-widest mb-3">Os nossos especialistas</p>
        <h2 class="font-(--font-display) text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">Conhece os<br /><span style="background: linear-gradient(135deg, var(--color-gold-400), var(--color-gold-600)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Artistas</span></h2>
        <p class="mt-4 text-gray-500 max-w-md mx-auto text-sm leading-relaxed">Cada artista tem a sua especialidade. Clica para ver os seus trabalhos.</p>
      </div>
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {artists.map((artist) => <ArtistCard artist={artist} />)}
      </div>
    </div>
  </section>

  <section id="categorias" class="py-24 lg:py-32 bg-(--color-dark-900)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal text-center mb-16">
        <p class="text-(--color-gold-500) text-xs font-medium uppercase tracking-widest mb-3">Explora por zona</p>
        <h2 class="font-(--font-display) text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">Onde queres<br /><span style="background: linear-gradient(135deg, var(--color-gold-400), var(--color-gold-600)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">o teu piercing?</span></h2>
        <p class="mt-4 text-gray-500 max-w-md mx-auto text-sm leading-relaxed">Navega pela galeria por zona do corpo e inspira-te para o teu proximo piercing.</p>
      </div>
      <div class="reveal grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {bodyParts.map((part) => <BodyPartCard bodyPart={part} />)}
      </div>
    </div>
  </section>

  <section id="sobre" class="py-24 lg:py-32 bg-(--color-dark-800)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-(--color-gold-500) text-xs font-medium uppercase tracking-widest mb-4">Sobre nos</p>
          <h2 class="font-(--font-display) text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">Mais de 10 anos<br />a fazer arte</h2>
          <div class="space-y-4 text-gray-500 text-sm leading-relaxed">
            <p>A NØVA Piercing Boutique nasceu no Porto com uma missão simples: trazer a mais alta qualidade artística ao mundo do piercing. Cada peça de joalharia é criteriosamente selecionada, cada procedimento executado com a máxima esterilização.</p>
            <p>A nossa equipa de 4 artistas especializados combina anos de experiência com uma paixão genuína pela arte corporal. Do piercing mais subtil ao projeto mais elaborado, estamos aqui para transformar a tua visão em realidade.</p>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-10">
            {[
              { icon: '✦', title: 'Higiene Total', desc: 'Esterilizacao certificada em todos os procedimentos' },
              { icon: '✦', title: 'Joias Premium', desc: 'Titanio ASTM F136 e ouro 14k/18k' },
              { icon: '✦', title: 'Acompanhamento', desc: 'Suporte completo na cicatrizacao' },
              { icon: '✦', title: 'Arte Unica', desc: 'Cada projeto e personalizado para ti' },
            ].map(val => (
              <div class="p-4 rounded-xl bg-(--color-dark-700) border border-black/8">
                <span class="text-(--color-gold-500)">{val.icon}</span>
                <h4 class="text-gray-900 font-medium text-sm mt-2 mb-1">{val.title}</h4>
                <p class="text-gray-500 text-xs leading-relaxed">{val.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal relative hidden lg:block">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="aspect-[3/4] rounded-2xl bg-(--color-dark-700) border border-black/8 flex items-center justify-center"><span class="text-(--color-gold-500)/20 text-7xl font-(--font-display) font-bold select-none">P</span></div>
              <div class="aspect-square rounded-2xl bg-(--color-dark-700) border border-black/8 flex items-center justify-center"><span class="text-(--color-gold-500)/20 text-5xl font-(--font-display) font-bold select-none">S</span></div>
            </div>
            <div class="space-y-4 pt-8">
              <div class="aspect-square rounded-2xl bg-(--color-dark-700) border border-black/8 flex items-center justify-center"><span class="text-(--color-gold-500)/20 text-5xl font-(--font-display) font-bold select-none">A</span></div>
              <div class="aspect-[3/4] rounded-2xl bg-(--color-dark-700) border border-black/8 flex items-center justify-center"><span class="text-(--color-gold-500)/20 text-7xl font-(--font-display) font-bold select-none">R</span></div>
            </div>
          </div>
          <div class="absolute -inset-4 rounded-3xl border border-(--color-gold-500)/15 -z-10 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-(--color-gold-500) relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-10" style="background-image: linear-gradient(rgba(255,255,255,.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="reveal relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/70 text-xs font-medium uppercase tracking-widest mb-4">Pronto para comecar?</p>
      <h2 class="font-(--font-display) text-4xl sm:text-5xl font-bold text-white mb-5">Marca a tua consulta</h2>
      <p class="text-white/80 text-base mb-10 max-w-lg mx-auto leading-relaxed">A primeira consulta e gratuita. Vem conhecer-nos e vamos criar juntos o teu proximo piercing de sonho.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:+351912345678" class="w-full sm:w-auto px-8 py-4 bg-white hover:bg-gray-100 text-(--color-gold-600) font-semibold rounded-full transition-all duration-300 hover:scale-105 uppercase tracking-wider text-sm flex items-center justify-center gap-2 shadow-lg">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          Ligar Agora
        </a>
        <a href="https://wa.me/351912345678" class="w-full sm:w-auto px-8 py-4 border-2 border-white/50 hover:border-white text-white font-medium rounded-full transition-all duration-300 uppercase tracking-wider text-sm flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          // aplica delay escalonado baseado na posição entre irmãos
          const siblings = Array.from(el.parentElement?.querySelectorAll('.reveal') ?? []);
          const index = siblings.indexOf(el);
          el.style.transitionDelay = `${index * 80}ms`;
          el.classList.add('revealed');
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
