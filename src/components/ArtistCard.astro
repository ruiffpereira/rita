---
import type { Artist } from '../data/artists';

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;
---

<a
  href={`/artista/${artist.id}`}
  class="group relative block overflow-hidden rounded-2xl bg-(--color-dark-700) border border-black/8 hover:border-(--color-gold-500)/60 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
  style="box-shadow: 0 0 0 0 transparent;"
>
  <!-- Image container -->
  <div class="aspect-[3/4] overflow-hidden bg-(--color-dark-600) relative">
    <img
      src={artist.image}
      alt={`Foto de ${artist.name}`}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
      onerror="this.style.display='none'"
    />
    <!-- Placeholder when no image -->
    <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-(--color-dark-700) to-(--color-dark-900)">
      <span class="text-6xl font-bold text-(--color-gold-500)/30 font-(--font-display) select-none">
        {artist.name.charAt(0)}
      </span>
    </div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-(--color-dark-900) via-(--color-dark-900)/20 to-transparent"></div>
  </div>

  <!-- Content overlay -->
  <div class="absolute bottom-0 left-0 right-0 p-5">
    <p class="text-(--color-gold-400) text-xs font-medium uppercase tracking-widest mb-1">{artist.specialty}</p>
    <h3 class="font-(--font-display) text-2xl font-bold text-gray-900 mb-1 leading-tight">{artist.name}</h3>

    <!-- Works count + arrow row -->
    <div class="flex items-center justify-between mt-2">
      <span class="text-gray-600 text-xs">{artist.worksCount}+ trabalhos</span>
      <span class="text-(--color-gold-400) text-xs font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0 transition-all duration-300">
        Ver galeria
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>

  <!-- Gold glow on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"
    style="box-shadow: inset 0 0 40px 0 color-mix(in srgb, var(--color-gold-500) 8%, transparent);">
  </div>
</a>
