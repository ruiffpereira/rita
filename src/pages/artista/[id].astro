---
import Layout from '../../layouts/Layout.astro';
import { artists } from '../../data/artists';

export function getStaticPaths() {
  return artists.map((artist) => ({
    params: { id: artist.id },
    props: { artist },
  }));
}

const { artist } = Astro.props;

// Placeholder gallery — replace with real images
const galleryItems = Array.from({ length: 12 }, (_, i) => ({
  id: i + 1,
  src: `/images/gallery/${artist.id}/work${i + 1}.jpg`,
  alt: `Trabalho ${i + 1} de ${artist.name}`,
  tall: i % 3 === 0,
}));
---

<Layout title={artist.name} description={`Trabalhos de ${artist.name} — ${artist.specialty} | PIERCE Studio`}>

  <!-- Artist Hero -->
  <section class="pt-32 pb-16 bg-(--color-dark-900) relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/2 left-1/3 w-96 h-96 rounded-full blur-[120px]"
        style="background: color-mix(in srgb, var(--color-gold-500) 5%, transparent);"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-gray-600 mb-10">
        <a href="/" class="hover:text-(--color-gold-400) transition-colors">Home</a>
        <span>/</span>
        <a href="/#artistas" class="hover:text-(--color-gold-400) transition-colors">Artistas</a>
        <span>/</span>
        <span class="text-gray-400">{artist.name}</span>
      </nav>

      <div class="flex flex-col md:flex-row gap-10 items-start">
        <!-- Photo -->
        <div class="w-full md:w-56 lg:w-72 shrink-0">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden bg-(--color-dark-700) border border-white/10 relative flex items-center justify-center">
            <span class="text-8xl font-bold text-(--color-gold-500)/15 font-(--font-display) select-none absolute">
              {artist.name.charAt(0)}
            </span>
            <img
              src={artist.image}
              alt={`Foto de ${artist.name}`}
              class="absolute inset-0 w-full h-full object-cover"
              loading="eager"
              onerror="this.style.display='none'"
            />
          </div>
        </div>

        <!-- Info -->
        <div class="flex-1 pt-2">
          <p class="text-(--color-gold-400) text-xs font-medium uppercase tracking-widest mb-3">{artist.specialty}</p>
          <h1 class="font-(--font-display) text-5xl sm:text-6xl font-bold text-white mb-5 leading-tight">
          <span style="background: linear-gradient(135deg, #ffffff, var(--color-gold-500)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            {artist.name}
          </span></h1>
          <p class="text-gray-400 text-base leading-relaxed max-w-xl mb-8">{artist.bio}</p>

          <div class="flex flex-wrap items-center gap-6">
            <div>
              <p class="font-(--font-display) text-4xl font-bold text-white">{artist.worksCount}+</p>
              <p class="text-gray-600 text-xs uppercase tracking-widest mt-1">Trabalhos</p>
            </div>
            {artist.instagram && (
              <a
                href={`https://instagram.com/${artist.instagram.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 rounded-full border border-white/15 hover:border-(--color-gold-500)/50 text-gray-400 hover:text-(--color-gold-400) transition-all text-sm"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                {artist.instagram}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-16 bg-(--color-dark-800)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <h2 class="font-(--font-display) text-3xl font-bold text-white">Trabalhos</h2>
        <span class="text-gray-600 text-sm">{artist.worksCount}+ peças</span>
      </div>

      <!-- Masonry gallery -->
      <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 [column-gap:0.75rem]">
        {galleryItems.map((item) => (
          <div class="break-inside-avoid mb-3 group relative overflow-hidden rounded-xl bg-(--color-dark-700) border border-white/5 hover:border-(--color-gold-500)/30 transition-all duration-300 cursor-zoom-in">
            <div class={item.tall ? 'aspect-[3/4]' : 'aspect-square'}>
              <img
                src={item.src}
                alt={item.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                onerror="this.style.display='none'"
              />
              <!-- Placeholder -->
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-(--color-gold-500)/10 text-4xl font-(--font-display) font-bold select-none">{item.id}</span>
              </div>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-gray-700 text-xs mt-12">
        Adiciona as tuas fotos em <code class="text-(--color-gold-600)">/public/images/gallery/{artist.id}/</code> com os nomes work1.jpg, work2.jpg, etc.
      </p>
    </div>
  </section>

</Layout>
