---
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-(--color-gold-500) to-(--color-gold-700) flex items-center justify-center shadow-lg">
          <span class="text-white font-bold text-sm font-(--font-display)">N</span>
        </div>
        <span class="font-(--font-display) text-xl font-bold tracking-wider text-gray-900 group-hover:text-(--color-gold-500) transition-colors duration-200">
          Piercing Boutique<span class="text-(--color-gold-500)">.</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/#artistas" class="text-sm font-medium text-gray-500 hover:text-(--color-gold-500) transition-colors duration-200 tracking-widest uppercase">Artistas</a>
        <a href="/#categorias" class="text-sm font-medium text-gray-500 hover:text-(--color-gold-500) transition-colors duration-200 tracking-widest uppercase">Categorias</a>
        <a href="/#sobre" class="text-sm font-medium text-gray-500 hover:text-(--color-gold-500) transition-colors duration-200 tracking-widest uppercase">Sobre</a>
      </nav>

      <!-- CTA -->
      <div class="hidden md:flex">
        <a
          href="/#contacto"
          class="px-5 py-2 bg-(--color-gold-500) hover:bg-(--color-gold-400) text-white text-sm font-semibold rounded-full transition-all duration-300 hover:scale-105 hover:shadow-lg tracking-wider uppercase"
        >
          Marcar Consulta
        </a>
      </div>

      <!-- Mobile menu btn -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-500 hover:text-(--color-gold-500) transition-colors"
        aria-label="Abrir menu"
        aria-expanded="false"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-(--color-dark-900)/98 backdrop-blur-md border-t border-black/10"
  >
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col gap-1">
      <a href="/#artistas" class="mobile-link py-3 px-2 text-sm font-medium text-gray-600 hover:text-(--color-gold-500) transition-colors tracking-widest uppercase border-b border-black/5">Artistas</a>
      <a href="/#categorias" class="mobile-link py-3 px-2 text-sm font-medium text-gray-600 hover:text-(--color-gold-500) transition-colors tracking-widest uppercase border-b border-black/5">Categorias</a>
      <a href="/#sobre" class="mobile-link py-3 px-2 text-sm font-medium text-gray-600 hover:text-(--color-gold-500) transition-colors tracking-widest uppercase border-b border-black/5">Sobre</a>
      <a
        href="/#contacto"
        class="mobile-link mt-4 py-3 bg-(--color-gold-500) hover:bg-(--color-gold-400) text-white text-sm font-semibold rounded-full text-center tracking-wider uppercase transition-all"
      >
        Marcar Consulta
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll effect
  const onScroll = () => {
    if (window.scrollY > 40) {
      header.classList.add('bg-(--color-dark-900)/95', 'backdrop-blur-md', 'border-b', 'border-black/10', 'shadow-md');
    } else {
      header.classList.remove('bg-(--color-dark-900)/95', 'backdrop-blur-md', 'border-b', 'border-black/10', 'shadow-md');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
